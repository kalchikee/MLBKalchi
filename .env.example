# MLB Oracle v4.0 — Environment Variables
# Copy this file to .env and fill in your values.
# All alert variables are optional — alerts are graceful no-ops when unset.

# ─── Discord Alerts ─────────────────────────────────────────────────────────
# Create a webhook in: Discord Server → Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Email Alerts (Resend) ───────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_...
RESEND_FROM=mlb-oracle@yourdomain.com
RESEND_TO=you@email.com

# ─── OpenAI (optional future use) ───────────────────────────────────────────
OPENAI_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Optional: override default path (./data/mlb_oracle.db)
DB_PATH=./data/mlb_oracle.db

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_DIR=./cache
# How long to cache MLB API responses (hours, default 1)
CACHE_TTL_HOURS=1

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
